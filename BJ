    function render()
        for _, v in pairs(list:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end

        local filteredCache = {}
        for _, d in ipairs(cache) do 
            local viewPass = false
            if currentViewTier == "All" then viewPass = true
            elseif currentViewTier == "Midlights" and d.tier == "Midlights" then viewPass = true
            elseif currentViewTier == "Highlights+" and (d.tier == "Highlights" or d.tier == "Peaklights") then viewPass = true end 

            local mutPass = false
            local lMut = d.mutation:lower()
            if currentMutationFilter == "All" then mutPass = true
            elseif currentMutationFilter == "Gold" and lMut:find("gold") then mutPass = true
            elseif currentMutationFilter == "Diamond" and lMut:find("diamond") then mutPass = true
            elseif currentMutationFilter == "Rainbow" and lMut:find("rainbow") then mutPass = true
            elseif currentMutationFilter == "Others" then
                if lMut ~= "none" and lMut ~= "" and not (lMut:find("gold") or lMut:find("diamond") or lMut:find("rainbow")) then 
                    mutPass = true 
                end
            end

            if viewPass and mutPass then
                table.insert(filteredCache, d)
            end
        end

        table.sort(filteredCache, function(a, b)
            if sortMode == "Value" then return a.raw > b.raw else return a.time > b.time end
        end)

        local renderLimit = isMobile and 30 or 50 
        local count = 0

        for _, d in ipairs(filteredCache) do
            count = count + 1
            if count > renderLimit then break end

            local isBlacklisted = blacklistedNames[d.baseName] or false
            local defaultThemeBg = skinFrameRegistry[main] and (currentSkin == "Default" and Color3.fromRGB(35, 35, 50) or Themes[currentSkin].Sec) or Color3.fromRGB(35, 35, 50)
            local targetBgColor = isBlacklisted and Color3.fromRGB(20, 20, 25) or defaultThemeBg

