    local function getCornerRadius(base)
        if currentCornerStyle == "Square" then return UDim.new(0, 0)
        elseif currentCornerStyle == "Squircle" then return UDim.new(0, math.floor(base * 1.8))
        else return UDim.new(0, base) end
    end

    local function applyRounded(instance, radius)
        local corner = instance:FindFirstChildWhichIsA("UICorner") or Instance.new("UICorner")
        corner.Parent = instance
        cornerRegistry[corner] = radius or 6
        corner.CornerRadius = getCornerRadius(radius or 6)
    end

    local function updateCornersInstantly()
        for corner, base in pairs(cornerRegistry) do
            if corner and corner.Parent then
                corner.CornerRadius = getCornerRadius(base)
            end
        end
    end

    local function applyStroke(instance, color)
        local stroke = instance:FindFirstChildWhichIsA("UIStroke") or Instance.new("UIStroke")
        stroke.Color = color or Color3.fromRGB(60, 60, 80)
        stroke.Thickness = 1
        stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        stroke.Parent = instance
        strokeRegistry[stroke] = {defaultColor = color or Color3.fromRGB(60, 60, 80)}
    end

    local function registerSkinFrame(frame, defaultBg, isMain)
        skinFrameRegistry[frame] = {bg = defaultBg, main = isMain}
