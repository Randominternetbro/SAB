    local function setupCameraZoom(parentVP, targetCFrame, targetSize)
        local cam = Instance.new("Camera", parentVP)
        parentVP.CurrentCamera = cam
        local maxDim = math.max(targetSize.X, targetSize.Y, targetSize.Z)
        if maxDim < 1 then maxDim = 1 end
        local currentZoom = maxDim * zoomMultiplier
        local minZoom, maxZoom = maxDim * 0.8, maxDim * 4.0
        local function updateCamera() cam.CFrame = CFrame.new(targetCFrame.Position + Vector3.new(0, maxDim * 0.1, currentZoom), targetCFrame.Position) end
        updateCamera()
        parentVP.Active = true
        addConnection(parentVP.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseWheel then
                currentZoom = math.clamp(currentZoom - (input.Position.Z * (maxDim * 0.3)), minZoom, maxZoom)
                updateCamera()
            end
        end))
    end

    local function createModel(parentVP, baseItemName)
        local wm = Instance.new("WorldModel", parentVP)
        local animalsFolder = ReplicatedStorage:FindFirstChild("Models") and ReplicatedStorage.Models:FindFirstChild("Animals")
        if animalsFolder and animalsFolder:FindFirstChild(baseItemName) then
            local model = animalsFolder[baseItemName]:Clone()
            model.Parent = wm
            
            local cframe, size = CFrame.new(), Vector3.new(2,2,2)
            local rotationCFrame = CFrame.Angles(0, math.rad(modelRotation), 0)
            
            if model:IsA("Model") then
                model:PivotTo(CFrame.new(0, 0, 0) * rotationCFrame)
                cframe, size = model:GetBoundingBox()
            elseif model:IsA("BasePart") then
                model.CFrame = CFrame.new(0, 0, 0) * rotationCFrame; cframe = model.CFrame; size = model.Size
            end
            setupCameraZoom(parentVP, cframe, size)

            -- ANIMACIONES
            if animationsEnabled then
                local animFolder = ReplicatedStorage:FindFirstChild("Animations") and ReplicatedStorage.Animations:FindFirstChild("Animals")
                if animFolder and animFolder:FindFirstChild(baseItemName) then
                    local targetAnim = animFolder[baseItemName]:FindFirstChild(currentAnimType)
                    if targetAnim then
                        local controller = model:FindFirstChild("Humanoid") or model:FindFirstChildWhichIsA("AnimationController")
                        if controller then
                            local animator = controller:FindFirstChild("Animator") or Instance.new("Animator", controller)
                            local track = animator:LoadAnimation(targetAnim)
                            track.Looped = true
                            track:Play()
                        end
                    end
                end
            end
        else
            local part = Instance.new("Part", wm); part.Size = Vector3.new(2, 2, 2); part.CFrame = CFrame.new(0,0,0)
            setupCameraZoom(parentVP, part.CFrame, part.Size)
        end
    end

