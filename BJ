    -- COLORES EXACTOS DE MUTACIONES
    local function getMutationStyle(name)
        if not name then return Color3.fromRGB(150, 150, 150), nil end
        local n = name:lower()
        if n:find("candy") then return Color3.fromRGB(255, 105, 180), nil 
        elseif n:find("galaxy") then return Color3.fromRGB(128, 0, 128), nil 
        elseif n:find("oro") or n:find("gold") then return Color3.fromRGB(255, 215, 0), nil 
        elseif n:find("diamond") or n:find("diamante") then return Color3.fromRGB(0, 255, 255), nil 
        elseif n:find("radiac") or n:find("radioac") or n:find("nuclear") then return Color3.fromRGB(57, 255, 20), nil 
        elseif n:find("arcoiris") or n:find("rainbow") then 
            return Color3.new(1,1,1), ColorSequence.new{
                ColorSequenceKeypoint.new(0, Color3.fromRGB(255,0,0)), ColorSequenceKeypoint.new(0.2, Color3.fromRGB(255,165,0)),
                ColorSequenceKeypoint.new(0.4, Color3.fromRGB(255,255,0)), ColorSequenceKeypoint.new(0.6, Color3.fromRGB(0,128,0)),
                ColorSequenceKeypoint.new(0.8, Color3.fromRGB(0,0,255)), ColorSequenceKeypoint.new(1, Color3.fromRGB(128,0,128))
            }
        elseif n:find("blood") then return Color3.fromRGB(200, 0, 0), nil 
        elseif n:find("ying") or n:find("yin") then 
            return Color3.new(1,1,1), ColorSequence.new{ 
                ColorSequenceKeypoint.new(0, Color3.fromRGB(0,0,0)), ColorSequenceKeypoint.new(0.49, Color3.fromRGB(0,0,0)),
                ColorSequenceKeypoint.new(0.51, Color3.fromRGB(255,255,255)), ColorSequenceKeypoint.new(1, Color3.fromRGB(255,255,255))
            }
        elseif n:find("divin") then 
            return Color3.new(1,1,1), ColorSequence.new{ 
                ColorSequenceKeypoint.new(0, Color3.fromRGB(255,215,0)), ColorSequenceKeypoint.new(1, Color3.fromRGB(255,255,255))
            }
        elseif n:find("lava") then return Color3.fromRGB(255, 140, 0), nil 
        elseif n:find("void") then return Color3.fromRGB(25, 0, 50), nil
        elseif n:find("shadow") then return Color3.fromRGB(15, 15, 15), nil
        elseif n:find("angel") then return Color3.fromRGB(255, 255, 240), nil
        elseif n:find("demon") then return Color3.fromRGB(139, 0, 0), nil
        elseif n:find("cosmic") then return Color3.fromRGB(25, 25, 112), nil
        end
        return Color3.fromRGB(150, 150, 150), nil
    end

