    local function updateUIStyles()
        updateCornersInstantly()
        local theme = Themes[currentSkin] or Themes.Default
        for frame, data in pairs(skinFrameRegistry) do
            if frame.Parent then
                if currentSkin == "Default" then
                    frame.BackgroundColor3 = data.bg
                    frame.BackgroundTransparency = bgTransparency
                else
                    if data.main then
                        frame.BackgroundColor3 = theme.Main
                        frame.BackgroundTransparency = math.max(0.1, bgTransparency)
                    else
                        frame.BackgroundColor3 = theme.Sec
                        frame.BackgroundTransparency = currentSkin == "Cloudy" and 0.85 or bgTransparency
                    end
                end
            end
        end
        for stroke, data in pairs(strokeRegistry) do
            if stroke.Parent then
                if currentSkin == "Default" then stroke.Color = data.defaultColor; stroke.Transparency = 0
                else stroke.Color = theme.Stroke; stroke.Transparency = currentSkin == "Cloudy" and 0.7 or 0 end
            end
        end
        for txt, data in pairs(textRegistry) do
            if txt.Parent then
                if currentSkin == "Default" then txt.TextColor3 = data.defaultColor else txt.TextColor3 = theme.Text end
            end
        end
    end

    local function deepcopy(orig)
        local orig_type = type(orig)
        local copy
        if orig_type == 'table' then
            copy = {}
            for orig_key, orig_value in next, orig, nil do
                copy[deepcopy(orig_key)] = deepcopy(orig_value)
            end
            setmetatable(copy, deepcopy(getmetatable(orig)))
        else copy = orig end
        return copy
    end

