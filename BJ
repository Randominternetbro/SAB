    -- LOOP WEBHOOK (Caché Busted para Estabilidad)
    task.spawn(function()
        while isRunning do
            local url = WEBHOOK .. "?nocache=" .. tostring(tick())
            local ok, res = pcall(function() return game:HttpGet(url) end)
            if ok then
                local suc, data = pcall(function() return HttpService:JSONDecode(res) end)
                if suc and data and data.findings then
                    local newItemsAdded = false
                    for _, v in ipairs(data.findings) do
                        if not seen[v.id] then
                            seen[v.id] = true
                            local val = tonumber(v.value) or 0
                            local tier = (v.tier or "Unknown"):gsub("PeakLights", "Peaklights") 
                            local mut = v.mutation or "None"

                            if val >= minListValue then
                                local baseNm = v.base_name or v.name or "Unknown"
                                local nameObj = v.name or "Unknown"
                                local d = { id = v.id, name = nameObj, baseName = baseNm, value = format(val), raw = val, tier = tier, mutation = mut, jobId = v.job_id, time = v.timestamp or 0, localTime = tick() }
                                
                                table.insert(cache, d)
                                if #cache > 150 then table.remove(cache, 1) end
                                newItemsAdded = true

                                if not isManualReload then 
                                    -- SISTEMA DE FAVORITOS (Auto-Forzado)
                                    if favoritesEnabled and favorites[baseNm] and not activeForces[d.id] then
                                        activeForces[d.id] = {active = true, data = d}
                                        updateForceUI()
                                        task.spawn(function()
                                            while activeForces[d.id] and isRunning do
                                                if activeForces[d.id].active then
                                                    if joinAttempts[d.id] then joinAttempts[d.id] = joinAttempts[d.id] + 1 else joinAttempts[d.id] = 1 end
                                                    local fJobStr = tostring(activeForces[d.id].data.jobId)
                                                    pcall(function() TeleportService:TeleportToPlaceInstance(PLACE_ID, fJobStr, player) end)
                                                end
                                                task.wait(forceDelay)
                                            end
                                        end)
                                    end

                                    local notifThresholdMet = false
                                    if tier == "Midlights" and val >= notifMinMidValue then notifThresholdMet = true
                                    elseif tier == "Highlights" and val >= notifMinHighValue then notifThresholdMet = true
                                    elseif tier == "Peaklights" and val >= notifMinPeakValue then notifThresholdMet = true end

                                    if notifThresholdMet and activeNotifTiers[tier] then
                                        customNotify(d.name, "$" .. d.value .. "/s | Tier: " .. tier, tier, d.jobId, d.id)
                                    end

                                    -- ARREGLO AUTOJOIN (Verifica activeAutoTiers)
                                    if autoJoin and firstFetchDone and val >= minAutoValue and activeAutoTiers[tier] == true and not blacklistedNames[baseNm] then
                                        executeJoinAttempts(d.id, d.jobId, maxJoinAttempts)
                                    end
                                end
                            end
                        end
                    end
                    if newItemsAdded then 
                        lastItemReceived = tick()
                        pcall(render) 
                    end
                end
            end
            task.wait(fetchInterval) 
        end
    end)

