    local function createSlider(parent, text, minVal, maxVal, currentVal, x, y, width, callback, releaseCallback)
        local frame = Instance.new("Frame", parent)
        frame.Position = UDim2.new(0, x, 0, y)
        frame.Size = UDim2.new(0, width, 0, 30)
        frame.BackgroundTransparency = 1

        local lbl = Instance.new("TextLabel", frame)
        lbl.Size = UDim2.new(1, 0, 0, 15)
        lbl.BackgroundTransparency = 1
        lbl.Text = text .. ": " .. currentVal
        lbl.TextColor3 = Color3.fromRGB(200, 200, 200)
        lbl.Font = Enum.Font.GothamSemibold
        lbl.TextSize = 11
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        registerSkinText(lbl, lbl.TextColor3)

        local track = Instance.new("TextButton", frame)
        track.Size = UDim2.new(1, 0, 0, 8)
        track.Position = UDim2.new(0, 0, 0, 18)
        track.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
        track.Text = ""
        applyRounded(track, 4)
        applyStroke(track)

        local fill = Instance.new("Frame", track)
        fill.Size = UDim2.new(math.clamp((currentVal - minVal) / (maxVal - minVal), 0, 1), 0, 1, 0)
        fill.BackgroundColor3 = uiColor
        applyRounded(fill, 4)

        local function updateSlider(input)
            local relX = math.clamp(input.Position.X - track.AbsolutePosition.X, 0, track.AbsoluteSize.X)
            local percent = relX / track.AbsoluteSize.X
            local val = math.floor(minVal + (maxVal - minVal) * percent)
            fill.Size = UDim2.new(percent, 0, 1, 0)
            lbl.Text = text .. ": " .. val
            callback(val)
        end

        local dragging = false
        addConnection(track.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true; updateSlider(input)
            end
        end))
        addConnection(UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                if dragging then dragging = false; if releaseCallback then releaseCallback() end end
            end
        end))
        addConnection(UserInputService.InputChanged:Connect(function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then 
                updateSlider(input) 
            end
        end))

        local updateFunc = function(newVal, newColor)
            local percent = math.clamp((newVal - minVal) / (maxVal - minVal), 0, 1)
            fill.Size = UDim2.new(percent, 0, 1, 0)
            lbl.Text = text .. ": " .. newVal
            if newColor then fill.BackgroundColor3 = newColor end
        end
        return updateFunc, frame
    end

    local function makeDraggable(guiObj)
        local dragging, dragInput, dragStart, startPos
        addConnection(guiObj.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true; dragStart = input.Position; startPos = guiObj.Position
                addConnection(input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end))
            end
        end))
        addConnection(guiObj.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
        end))
        addConnection(UserInputService.InputChanged:Connect(function(input)
            if input == dragInput and dragging then
                local delta = input.Position - dragStart
                guiObj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end))
    end
