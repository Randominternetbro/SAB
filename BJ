    local function executeJoinAttempts(itemId, jobId, attempts, updateUifunc)
        task.spawn(function()
            local jIdStr = tostring(jobId)
            local targetAttempts = autoRetryEnabled and attempts or 1
            for i = 1, targetAttempts do
                if not isRunning then break end
                pcall(function() TeleportService:TeleportToPlaceInstance(PLACE_ID, jIdStr, player) end)
                if joinAttempts[itemId] then joinAttempts[itemId] = joinAttempts[itemId] + 1 else joinAttempts[itemId] = 1 end
                if updateUifunc then pcall(updateUifunc) end 
                if i < targetAttempts then task.wait(forceDelay > 0.5 and forceDelay or 0.5) end
            end
        end)
    end

